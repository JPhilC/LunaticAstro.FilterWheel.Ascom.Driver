<UserControl x:Class="ASCOM.LunaticAstro.FilterWheel.FilterWheelDriver.Views.SetupDialogControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:ASCOM.LunaticAstro.FilterWheel.FilterWheelDriver.ViewModel"
             mc:Ignorable="d"
             MinWidth="460" MinHeight="210">

    <UserControl.DataContext>
        <vm:SetupViewModel />
    </UserControl.DataContext>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top description -->
        <TextBlock Grid.Row="0"
                   Text="Construct your driver's setup dialog here."
                   TextWrapping="Wrap"
                   Margin="0,0,0,10"
                   FontSize="14"/>

        <!-- ASCOM logo -->
        <Image Grid.Row="0"
               HorizontalAlignment="Right"
               Width="48"
               Height="56"
               Cursor="Hand"
               Margin="0,0,0,10"
               Source="/ASCOM.LunaticAstro.FilterWheel.FilterWheelDriver;component/Resources/ascom_logo.png"
               MouseLeftButtonUp="BrowseToAscom"/>

        <!-- COM Port -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
            <TextBlock Text="Comm Port" VerticalAlignment="Center" Width="80"/>
            <ComboBox Width="180"
                      Margin="10,0,0,0"
                      ItemsSource="{Binding ComPorts}"
                      SelectedItem="{Binding SelectedComPort}" />
        </StackPanel>

        <!-- Trace checkbox -->
        <CheckBox Grid.Row="2"
                  Content="Trace on"
                  Margin="90,10,0,0"
                  IsChecked="{Binding TraceEnabled}" />

        <!-- Buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,20,0,0">
            <Button Width="80"
                    Height="28"
                    Margin="0,0,10,0"
                    Content="OK"
                    Command="{Binding OkCommand}" />

            <Button Width="80"
                    Height="28"
                    Content="Cancel"
                    Command="{Binding CancelCommand}" />
        </StackPanel>

    </Grid>
</UserControl>